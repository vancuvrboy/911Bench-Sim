    "test_id": "CAD-010",
    "category": "cad_occ",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "governance_patch",
        "action_id": "a1",
        "payload": {
          "remarks_notes": "alpha"
        },
        "read_set": {
          "record_version": 0,
          "field_versions": {
            "remarks_notes": 0
          }
        }
      },
      {
        "action": "governance_patch",
        "action_id": "a2",
        "payload": {
          "remarks_notes": "beta"
        },
        "read_set": {
          "record_version": 1,
          "field_versions": {
            "remarks_notes": 1
          }
        }
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "final_cad_state": {
        "remarks_notes": "alpha\nbeta"
      }
    }
  }
