  {
    "test_id": "CAD-004",
    "category": "cad_occ",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "governance_patch",
        "action_id": "a1",
        "action_class": "cad_update.address",
        "payload": {
          "location": "100 Granville"
        },
        "read_set": {
          "record_version": 0,
          "field_versions": {
            "location": 0
          }
        }
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "final_cad_state": {
        "location": "100 Granville"
      },
      "final_record_version_min": 1
    }
  },
