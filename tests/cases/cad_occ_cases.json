  {
    "test_id": "CAD-002",
    "category": "cad_occ",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "caller_turn",
        "text": "Need help"
      },
      {
        "action": "calltaker_turn",
        "text": "Location?",
        "cad_updates": {
          "location": "2421 Main Street"
        }
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "final_record_version_min": 1,
      "final_cad_state": {
        "location": "2421 Main Street"
      }
    }
  },
