[
  {
    "test_id": "CHKP-001",
    "category": "checkpoint",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "checkpoint_request",
        "request": {
          "action_class": "cad_update.priority",
          "proposed_payload": {
            "priority": "high"
          },
          "evidence_summary": "caller panic",
          "approver_role": "call_taker",
          "source": "checkpoint",
          "timeout_ms": 5000
        }
      },
      {
        "action": "checkpoint_poll"
      },
      {
        "action": "checkpoint_submit",
        "decision": "approved"
      },
      {
        "action": "checkpoint_poll"
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "events_schema_valid": true,
      "event_types_present": [
        "checkpoint_decision"
      ]
    }
  },
