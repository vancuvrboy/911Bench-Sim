  {
    "test_id": "E2E-005",
    "category": "e2e",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "checkpoint_request",
        "request": {
          "action_class": "cad_update.priority",
          "proposed_payload": {
            "priority": "high"
          },
          "evidence_summary": "risk",
          "approver_role": "call_taker",
          "source": "checkpoint",
          "timeout_ms": 5000
        }
      },
      {
        "action": "checkpoint_submit",
        "decision": "approved"
      },
      {
        "action": "governance_patch",
        "action_id": "e5",
        "payload": {
          "priority": "high"
        },
        "read_set": {
          "record_version": 0,
          "field_versions": {
            "priority": 0
          }
        },
        "checkpoint_ref": "req",
        "checkpoint_decision": "approved"
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "event_types_present": [
        "checkpoint_decision",
        "cad_patch_applied"
      ]
    }
  },
  {
