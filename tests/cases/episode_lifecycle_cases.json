    }
  },
  {
    "test_id": "LIFE-007",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      },
      {
        "action": "governance_patch",
        "action_id": "l7",
        "payload": {
          "priority": "high"
        },
        "read_set": {
          "record_version": 0,
          "field_versions": {
            "priority": 0
          }
        }
      }
    ],
    "expected": {
      "error_contains": "episode is sealed"
    }
  },
  {
    "test_id": "LIFE-008",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      },
      {
        "action": "emit_event",
        "event": {
          "event_type": "governance_correlation",
          "action_id": "x",
          "matched_rule_ids": [
            "r"
          ],
          "policy_id": "p"
        }
      }
    ],
    "expected": {
      "error_contains": "episode is sealed"
    }
  },
  {
    "test_id": "LIFE-009",
