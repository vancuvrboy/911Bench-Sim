[
  {
    "test_id": "LIFE-001",
    "category": "episode_lifecycle",
    "deterministic": true,
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "caller_turn",
        "text": "There is a fire at 2421 Main!"
      },
      {
        "action": "calltaker_turn",
        "text": "Confirming 2421 Main.",
        "cad_updates": {
          "location": "2421 Main Street"
        }
      },
      {
        "action": "end_call",
        "reason": "resolved_no_dispatch"
      }
    ],
    "expected": {
      "episode_sealed": true,
      "event_count_min": 4,
      "event_types_present": [
        "meta",
        "conversation",
        "episode_end"
      ],
      "final_cad_state": {
        "location": "2421 Main Street"
      },
      "final_record_version_min": 1,
      "events_schema_valid": true
    }
  },
  {
    "test_id": "LIFE-002",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario",
        "caller_json": "fixtures/caller_missing_name.json"
      }
    ],
    "expected": {
      "error_contains": "identity.name"
    }
  },
  {
    "test_id": "LIFE-003",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario",
        "incident_json": "fixtures/incident_invalid_type.json"
      }
    ],
    "expected": {
      "error_contains": "invalid type enum"
    }
  },
  {
    "test_id": "LIFE-004",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "start_episode"
      }
    ],
    "expected": {
      "error_contains": "incident_id not found"
    }
  },
  {
    "test_id": "LIFE-005",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "start_episode"
      },
      {
        "action": "start_episode"
      }
    ],
    "expected": {
      "error_contains": "already running"
    }
  },
  {
    "test_id": "LIFE-006",
    "category": "episode_lifecycle",
    "script": [
      {
        "action": "load_scenario"
      },
      {
        "action": "caller_turn",
        "text": "Hello"
      }
    ],
    "expected": {
